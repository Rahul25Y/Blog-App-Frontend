# ============================================
# Blog Application Frontend - Environment Configuration
# ============================================
#
# This file serves as a template for environment variables.
# Copy this file to .env and update with your actual values.
#
# IMPORTANT: 
# - Never commit .env file to version control (it's in .gitignore)
# - All VITE_ prefixed variables are exposed to client-side code
# - Backend URL must be accessible from the client browser
# - For Vercel/production deployment, add these variables in:
#   Settings → Environment Variables
#
# ============================================
# API Configuration
# ============================================
#
# Backend API Base URL for the Blog Application
#
# Local Development:
#   VITE_API_BASE_URL=http://localhost:4000/api/v1
#
# Production/Vercel Deployment:
#   VITE_API_BASE_URL=https://your-backend-domain.com/api/v1
#   or
#   VITE_API_BASE_URL=https://your-railway-url.railway.app/api/v1
#
# Replace 'your-backend-domain.com' with your actual backend URL
#
# Note: In Vite, environment variables must be prefixed with VITE_ 
# to be exposed to client-side code.
#
VITE_API_BASE_URL=http://localhost:4000/api/v1

# ============================================
# Build Output
# ============================================
#
# The application builds to the 'dist' directory
# Vercel will automatically serve the dist folder as static assets
#
